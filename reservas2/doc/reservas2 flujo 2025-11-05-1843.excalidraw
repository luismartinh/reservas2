      ],
      "updated": 1763681983622,
      "link": null,
      "locked": false,
      "text": "Pagina de busqueda de disponibilidad:\n(El usuario consulta por disponibilidad:)\ndesde - hasta + pax\nselecciona las cabañas:\n(se muestran las tarifas)\nSe toman en cuenta las reservas \n - confirmadas\n- verificar (no vencidas)\n[Solicitar recerva]",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pagina de busqueda de disponibilidad:\n(El usuario consulta por disponibilidad:)\ndesde - hasta + pax\nselecciona las cabañas:\n(se muestran las tarifas)\nSe toman en cuenta las reservas \n - confirmadas\n- verificar (no vencidas)\n[Solicitar recerva]",
      "autoResize": true,
      "lineHeight": 1.25
    },
